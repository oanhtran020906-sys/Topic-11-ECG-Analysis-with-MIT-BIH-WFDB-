   "source": [
    "filter Heart Rate"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 6,
   "id": "97494c9a",
   "metadata": {},
   "outputs": [],
   "source": [
    "import wfdb\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "from wfdb import processing\n",
    "\n",
    "record = wfdb.rdrecord(\"100\", pn_dir=\"mitdb\")\n",
    "signal = record.p_signal[:, 0]\n",
    "fs = record.fs\n",
    "\n",
    "# R-peak detection\n",
    "r_peaks = processing.gqrs_detect(sig=signal, fs=fs)\n",
    "\n",
    "# RR intervals\n",
    "rr_intervals = np.diff(r_peaks) / fs\n",
    "\n",
    "# Heart rate\n",
    "heart_rate = 60 / rr_intervals\n",
    "\n",
    "# Time index\n",
    "rr_times = r_peaks[1:] / fs\n",
    "\n",
    "hr_series = pd.Series(heart_rate, index=rr_times)"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "26dc2ceb",
   "metadata": {},
   "source": [
    "Filtering Outlier"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 15,
   "id": "312c3d94",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Outliers removed: 45\n"
     ]
    }
   ],
   "source": [
    "hr_clean = hr_series.copy()\n",
    "\n",
    "# 1. Physiological filter (giữ lại cho report)\n",
    "mask_phys = (hr_clean < 40) | (hr_clean > 180)\n",
    "\n",
    "# 2. Z-score filter (QUAN TRỌNG)\n",
    "z = (hr_clean - hr_clean.mean()) / hr_clean.std()\n",
    "mask_z = np.abs(z) > 3\n",
    "\n",
    "# Combine\n",
    "mask = mask_phys | mask_z\n",
    "\n",
    "# Apply\n",
    "hr_clean[mask] = np.nan\n",
    "\n",
    "print(\"Outliers removed:\", mask.sum())"
   ]
  },
